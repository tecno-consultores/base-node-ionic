FROM node:24-slim
LABEL maintainer="Jesus Palencia sinfallas@gmail.com"
LABEL build_date="2026-03-29"

ENV PNPM_HOME="/pnpm"
ENV PATH="/pnpm:/pnpm/bin:$PATH"
RUN corepack enable pnpm
RUN rm -rf /usr/local/bin/npm && ln -s /usr/local/bin/pnpm /usr/local/bin/npm
RUN pnpm config set global-bin-dir /pnpm/bin

WORKDIR /app
RUN apt update -qq && apt -y dist-upgrade && apt -y install --no-install-recommends --no-install-suggests tzdata s3fs && apt -y install --no-install-recommends --no-install-suggests awscli wget nano curl git && apt-get clean && apt -y autoremove && rm -rf /var/lib/{apt,dpkg,cache,log}
RUN pnpm add --global @ionic/cli
